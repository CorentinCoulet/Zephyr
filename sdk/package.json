{
  "name": "@astrafox/widget",
  "version": "0.1.0",
  "description": "Astrafox AI Navigation Assistant — Embeddable widget for any web project",
  "type": "module",
  "main": "dist/astrafox-widget.umd.js",
  "module": "dist/astrafox-widget.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/astrafox-widget.es.js",
      "require": "./dist/astrafox-widget.umd.js",
      "types": "./dist/types/index.d.ts"
    },
    "./react": {
      "import": "./react/index.jsx",
      "types": "./react/index.d.ts"
    },
    "./vue": {
      "import": "./vue/AstrafoxWidget.vue"
    }
  },
  "files": [
    "dist/",
    "react/",
    "vue/",
    "README.md"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js --watch"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "vue": { "optional": true }
  },
  "keywords": ["astrafox", "ai", "widget", "assistant", "navigation", "ux"],
  "license": "MIT"
}
