# ============================================
# 🦊 Zephyr — Environment Variables
# Copy to .env and fill in your values.
# All variables are optional — sensible defaults are used.
# ============================================

# --- App ---
ZEPHYR_APP_NAME=Zephyr Intelligence Platform
ZEPHYR_APP_VERSION=0.2.0
ZEPHYR_HOST=0.0.0.0
ZEPHYR_PORT=8000
ZEPHYR_DEBUG=false

# --- Target site to analyze ---
ZEPHYR_TARGET_URL=http://localhost:3000

# --- Theme ---
ZEPHYR_THEME=dark
ZEPHYR_VERSION=3

# --- LLM Providers ---
# LLM config is handled by zephyr.server.yaml, not env vars.
# These env vars are referenced in zephyr.server.yaml via ${VAR} syntax.
GITHUB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Widget SDK ---
# API key for widget authentication (leave empty to disable auth)
ZEPHYR_WIDGET_API_KEY=
# Public URL for the widget to connect back to (empty = auto-detect)
ZEPHYR_WIDGET_BASE_URL=

# --- Session ---
ZEPHYR_SESSION_TIMEOUT=1800
ZEPHYR_MAX_SESSIONS=50

# --- Browser ---
ZEPHYR_BROWSER_HEADLESS=true
ZEPHYR_BROWSER_TIMEOUT=30000
