# ============================================
# Astrafox — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- App ---
ASTRAFOX_APP_NAME=Astrafox Intelligence
ASTRAFOX_APP_VERSION=0.1.0
ASTRAFOX_HOST=0.0.0.0
ASTRAFOX_PORT=8000
ASTRAFOX_DEBUG=true

# --- Target ---
ASTRAFOX_TARGET_URL=http://localhost:3000

# --- Theme ---
ASTRAFOX_ASTRAFOX_THEME=dark
ASTRAFOX_ASTRAFOX_VERSION=3

# --- LLM ---
# LLM config is handled by astrafox.server.yaml, not env vars.
# See astrafox.server.yaml for provider settings.

# --- Session ---
ASTRAFOX_SESSION_TIMEOUT=1800
ASTRAFOX_MAX_SESSIONS=50
