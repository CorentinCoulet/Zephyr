# ============================================
# Astrafox — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- App ---
ASTRAFOX_APP_NAME=Astrafox Intelligence
ASTRAFOX_APP_VERSION=0.1.0
ASTRAFOX_HOST=0.0.0.0
ASTRAFOX_PORT=8000
ASTRAFOX_DEBUG=true

# --- Target ---
ASTRAFOX_TARGET_URL=http://localhost:3000

# --- Theme ---
ASTRAFOX_ASTRAFOX_THEME=dark
ASTRAFOX_ASTRAFOX_VERSION=minimal

# --- LLM Provider ---
# Options: openai, anthropic, ollama, local
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI
LLM_OPENAI_API_KEY=sk-your-key-here

# Anthropic (if using)
# LLM_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama (if using local)
# LLM_OLLAMA_BASE_URL=http://localhost:11434

# --- Session ---
ASTRAFOX_SESSION_TTL_MINUTES=60
ASTRAFOX_MAX_SESSIONS=50
