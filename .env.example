# ============================================
# Zephyr — Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- App ---
ZEPHYR_APP_NAME=Zephyr Intelligence
ZEPHYR_APP_VERSION=0.1.0
ZEPHYR_HOST=0.0.0.0
ZEPHYR_PORT=8000
ZEPHYR_DEBUG=true

# --- Target ---
ZEPHYR_TARGET_URL=http://localhost:3000

# --- Theme ---
ZEPHYR_THEME=dark
ZEPHYR_VERSION=3

# --- LLM ---
# LLM config is handled by zephyr.server.yaml, not env vars.
# See zephyr.server.yaml for provider settings.

# --- Session ---
ZEPHYR_SESSION_TIMEOUT=1800
ZEPHYR_MAX_SESSIONS=50
