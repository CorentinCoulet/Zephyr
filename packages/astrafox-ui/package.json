{
  "name": "@astrafox/ui",
  "version": "0.1.0",
  "description": "Astrafox — Embeddable AI assistant widget. Import <Astrafox /> into any React/Vue/JS project.",
  "type": "module",
  "main": "dist/astrafox.umd.cjs",
  "module": "dist/astrafox.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/astrafox.es.js",
      "require": "./dist/astrafox.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./config": {
      "import": "./dist/core/config.js",
      "types": "./dist/core/config.d.ts"
    },
    "./themes": {
      "import": "./dist/core/themes.js",
      "types": "./dist/core/themes.d.ts"
    },
    "./styles.css": "./dist/astrafox.css"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": [
    "astrafox",
    "ai",
    "widget",
    "chat",
    "assistant",
    "navigation",
    "react",
    "vue"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/astrafox"
  }
}
